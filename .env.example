# ==========================================
# Solana EMA Monitor - Environment Config
# ==========================================

# Birdeye API (Premium Plus recommended)
BIRDEYE_API_KEY=your_birdeye_api_key_here

# Trading Bot Webhook URLs
TRADING_BOT_BUY_URL=http://43.162.112.89:3002/webhook/new-token
TRADING_BOT_SELL_URL=http://43.162.112.89:3002/force-sell

# Server port
PORT=3001

# Token monitoring window — remove token after this many minutes
# Open positions are closed (SELL sent) before removal
TOKEN_MAX_AGE_MINUTES=60

# Minimum FDV (USD) — tokens below this are rejected immediately (no BUY)
# Tokens that drop below this while in position trigger a forced SELL
FDV_MIN_USD=10000

# EMA periods
EMA_FAST=9
EMA_SLOW=20

# Anti-shake: consecutive bars both BUY (or SELL) conditions must hold before firing
EMA_CONFIRM_BARS=2

# Price fetch interval (seconds) — one Birdeye call per token per interval
PRICE_POLL_SEC=5

# Candle width + EMA evaluation interval (seconds)
# Each candle contains KLINE_INTERVAL_SEC / PRICE_POLL_SEC price samples
KLINE_INTERVAL_SEC=15
